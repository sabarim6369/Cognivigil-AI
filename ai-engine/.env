# AI Engine Configuration

# Model Settings
MODELS_PATH=./models
YOLO_MODEL_PATH=./models/yolov8n.pt

# YOLO Configuration
YOLO_TARGET_CLASSES=["person", "cell phone", "book", "laptop", "mouse", "phone", "tablet", "notebook", "paper"]
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_NMS_THRESHOLD=0.4

# Face Tracking Configuration
FACE_MAX_FACES=1
FACE_MIN_DETECTION_CONFIDENCE=0.5
FACE_MIN_TRACKING_CONFIDENCE=0.5
FACE_LOOKING_AWAY_ANGLE_THRESHOLD=45.0
FACE_ABSENCE_THRESHOLD_SECONDS=3.0

# Risk Scoring Weights
RISK_PHONE_DETECTION_WEIGHT=50
RISK_MULTIPLE_PERSONS_WEIGHT=70
RISK_FACE_ABSENCE_WEIGHT=30
RISK_LOOKING_AWAY_WEIGHT=10
RISK_SUSPICIOUS_OBJECT_WEIGHT=20

# Risk Thresholds
RISK_THRESHOLD_LOW=25
RISK_THRESHOLD_MEDIUM=50
RISK_THRESHOLD_HIGH=75

# Detection Rules
PHONE_DETECTION_ENABLED=true
PHONE_DETECTION_COOLDOWN_SECONDS=5
MULTIPLE_PERSONS_ENABLED=true
MULTIPLE_PERSONS_MAX_ALLOWED=1
FACE_ABSENCE_ENABLED=true
LOOKING_AWAY_ENABLED=true
SUSPICIOUS_OBJECTS_ENABLED=true

# Performance Settings
MAX_BATCH_SIZE=10
PROCESSING_TIMEOUT_SECONDS=30
ENABLE_GPU_ACCELERATION=true

# Application Settings
DEBUG=true
LOG_LEVEL=info
